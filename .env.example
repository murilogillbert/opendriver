APP_ENV=development
APP_PORT=3001
CORS_ORIGIN=http://localhost:5173
# In production, JWT_SECRET MUST be set to a random value with at least 32 characters
# (e.g. `openssl rand -base64 48`). The example value below is rejected at boot in production.
JWT_SECRET=change_this_jwt_secret
# Lifespan of the JSON Web Tokens. Admin sessions default to 2h to limit blast radius if leaked.
ADMIN_TOKEN_TTL=2h
USER_TOKEN_TTL=7d
# One-shot shared secret required to call POST /api/auth/bootstrap-admin. In production, the API
# refuses to boot without it. Rotate or unset after the first admin is provisioned.
ADMIN_BOOTSTRAP_TOKEN=
UPLOAD_DIR=uploads
UPLOAD_MAX_BYTES=209715200
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_WEBHOOK_SECRET=

# Groq API key for the AI assistant (get yours free at https://console.groq.com)
GROQ_API_KEY=

SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=OpenDriver
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=Change_this_Strong_Password_123!

VITE_API_BASE_URL=http://localhost:3001/api
